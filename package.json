{
  "name": "warmth",
  "version": "2.0.0",
  "description": "Warmth — 情感沟通助手",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:portable": "node scripts/make-portable.js"
  },
  "build": {
    "appId": "com.warmth.emotional-agent",
    "productName": "Warmth",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.2.1",
    "electron-builder": "^24.0.0"
  }
}
